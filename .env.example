# =============================================================================
# GoonersBot - environment configuration
# Copy to .env and fill in. Never commit your real .env (it is gitignored).
# Required: TELEGRAM_BOT_TOKEN. Everything else has sensible defaults.
# This file documents EVERY option; .env only needs the ones you change.
# =============================================================================

# ---- Runtime ----
NODE_ENV=development               # development | production (production tightens logging)
LOG_LEVEL=info                     # pino level: trace | debug | info | warn | error | fatal

# ---- Telegram ----
# Get a token from @BotFather. REQUIRED.
TELEGRAM_BOT_TOKEN=                 # REQUIRED, format 123456:ABC... from @BotFather
# Default/hint only - the real username is resolved from Telegram at startup.
BOT_USERNAME=GoonersBot            # display hint only; real @username resolved at startup

# Access control. Comma-separated @handles.
# ALLOWED_HANDLES: who may use the bot. Empty or "*" => everyone (recommended for a public group).
# ADMIN_HANDLES: bot admins (can /ban, /unban). Empty => no bot admins.
ALLOWED_HANDLES=*                  # who may use the bot; "*" or empty = everyone
ADMIN_HANDLES=                     # admin @handles for /ban, /nsfw, /autopost, /approve; empty = none

# Approval gate: only bot admins, approved user ids, or approved chat ids get the model, media
# generation and link-media. Everyone else (incl. private DMs) is limited to tos/terms/help and
# gets the "request approval" notice. Seeded into APPROVED_STORE_PATH (JSON) on first run; manage
# at runtime with /approve, /unapprove, /approved. IDs are comma-separated; chat ids are negative.
APPROVED_CHATS=                    # e.g. -1002837751448 (your approved community chat ids)
APPROVED_USERS=                    # approved user ids (positive)
APPROVED_STORE_PATH=data/approved.json   # runtime JSON store of approvals

# ---- MongoDB ----
# Local Mongo (no Docker). Install/run MongoDB locally, e.g. `mongod --dbpath ./.mongo-data`.
MONGO_URI=mongodb://127.0.0.1:27017/goonerbot   # connection string (add ?authSource=... if auth on)
MONGO_DB=goonerbot                 # database name

# =============================================================================
# LLM provider
# Select ONE provider. The host is configurable - never hardcoded in the code.
# Supported: solclawn | openai | deepseek | ollama | custom_openai_compatible
# =============================================================================

# ---- Option A: solclawn (OpenAI-compatible LeakRouter surface) ----
# LLM_API_KEY is the LeakRouter client bearer token. LLM_MODEL is a model id the router serves.
LLM_PROVIDER=solclawn              # solclawn | openai | deepseek | ollama | custom_openai_compatible
LLM_BASE_URL=https://llm.solclawn.com/v1   # OpenAI-compatible base URL (must end in /v1)
LLM_API_KEY=                       # bearer token for the base URL (empty for a local Ollama)
LLM_MODEL=                         # primary chat model id (e.g. gemini-3.5-flash via router, or gpt-oss:20b)
# Optional media models (leave empty to disable that capability - the bot degrades gracefully):
# Vision: solclawn has NO vision. Run a vision model on a separate Ollama (recommended: the
# Kokoro/Windows box) and point LLM_VISION_BASE_URL at it. Empty base => reuses LLM_BASE_URL.
#   on that box:  ollama pull minicpm-v4.5:8b   (or: gemma4:12b / qwen3-vl / llama3.2-vision)
LLM_VISION_MODEL=                  # vision model id; empty = bot cannot see images/video frames
LLM_VISION_BASE_URL=               # separate vision endpoint; empty = reuse LLM_BASE_URL
LLM_VISION_API_KEY=                # api key for the vision endpoint; empty = none/reuse
LLM_IMAGE_MODEL=                   # server-side image-gen model; empty = no LLM image gen (SearXNG path still works)
# Transcription: local whisper.cpp (STT_* below) already covers voice/audio/video. This is only a
# remote OpenAI-style /audio/transcriptions fallback - leave empty when using local whisper.
LLM_TRANSCRIPTION_MODEL=           # remote transcription model; empty = use local whisper (STT_*)
LLM_TTS_MODEL=                     # remote text-to-speech model; empty = use the TTS_* block below
LLM_REQUEST_TIMEOUT_MS=60000       # per-request LLM timeout in ms

# Fallback chat endpoint (used when the primary LLM throws): e.g. a local Ollama on a GPU box.
# Active only when BOTH base URL and model are set. Vision/STT/etc. stay on the primary.
LLM_FALLBACK_BASE_URL=             # secondary endpoint used when primary throws; empty = no fallback
LLM_FALLBACK_MODEL=                # model on the fallback endpoint (needs BOTH url + model to activate)
LLM_FALLBACK_API_KEY=              # bearer token for the fallback endpoint

# ---- Embeddings (semantic RAG) ----
# MANDATORY default model: bge-m3 on Ollama (multilingual, local, zero-cost). 1024-dim.
# Served on the same Ollama box as the LLM fallback (OpenAI-compatible /v1/embeddings).
EMBEDDINGS_ENABLED=true
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
# Where the embeddings endpoint lives. Empty => reuse LLM_FALLBACK_BASE_URL, else LLM_BASE_URL.
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_API_KEY=
# Retrieval knobs:
RAG_GROUP_TOPK=6
RAG_KNOWLEDGE_TOPK=2
RAG_NEWS_TOPK=3
RAG_MIN_SCORE=0.30

# ---- Cortex (LLM-first reasoning evaluator) ----
# When true, the LLM cortex is the AUTHORITATIVE decision layer (regex is only a parachute).
CORTEX_LLM_ENABLED=true
# Model for the cortex JSON decision. Empty => reuse LLM_MODEL. A small/fast instruct model is ideal.
CORTEX_MODEL=
CORTEX_TEMPERATURE=0.1
CORTEX_MAX_TOKENS=1200

# If you change EMBEDDING_MODEL, you MUST update EMBEDDING_DIM to that model's dimension AND
# re-run the backfill. Vectors with the wrong dimension are skipped until backfilled.

# ---- Personality heat + on-demand knowledge ----
HEAT_ENABLED=true                  # let the bot escalate/de-escalate roast intensity per user
HEAT_BASELINE=12                   # starting heat score for a user (0-100)
HEAT_MAX=100                       # maximum heat score cap
HEAT_DECAY_PER_MINUTE=1            # heat points cooled per minute without escalation
KNOWLEDGE_ENABLED=true             # enable on-demand nerd/anime/manga/IT culture recall
KNOWLEDGE_MAX_ITEMS=2              # max knowledge snippets injected into one reply
KNOWLEDGE_SEED_ON_BOOT=true        # seed built-in knowledge entries at startup

# ---- Web/image grounding (free: self-hosted SearXNG + vision-model reverse-image lookup) ----
# Makes the bot "cultured": fresh web facts for recency/factual questions, and "who/what is this
# image / where to buy" answers by identifying the subject with the vision model and searching it.
# Run the free backend first:  scripts/searxng.sh setup && scripts/searxng.sh start
WEB_SEARCH_ENABLED=false           # enable SearXNG web grounding (fresh facts / recency)
SEARXNG_URL=http://127.0.0.1:8888  # your self-hosted SearXNG base URL
WEB_SEARCH_MAX_RESULTS=5           # how many search hits to feed the model
WEB_SEARCH_TIMEOUT_MS=8000         # search request timeout in ms
# IMAGE_LOOKUP: reverse-image grounding (needs WEB_SEARCH_ENABLED + LLM_VISION_MODEL).
IMAGE_LOOKUP_ENABLED=false         # reverse-image "who/what is this" lookups

# ---- Image sending + autonomous posting (needs SearXNG + a vision model) ----
# The bot occasionally drops a verified waifu/anime image (fetched online, vision-checked before
# sending) when the topic fits, and can post unprompted on a timer or via /news (/nuovo).
IMAGE_SEND_ENABLED=true            # allow the bot to attach images
IMAGE_SEND_PROBABILITY=0.15        # chance to attach an image on anime/waifu replies
IMAGE_QUERY_POOL=                  # comma-separated query seeds (defaults provided)

# ---- Stable Diffusion / Automatic1111 image generation ----
SD_ENABLED=true
SD_API_URL=http://192.168.178.87:7860
SD_MODEL=ponyDiffusionV6XL_v6StartWithThisOne.safetensors # legacy override for the default realistic checkpoint
# One shared checkpoint: do not create model-swap pressure on the Forge host.
SD_ANIME_MODEL=ponyDiffusionV6XL_v6StartWithThisOne.safetensors
SD_REALISTIC_MODEL=ponyDiffusionV6XL_v6StartWithThisOne.safetensors
SD_NSFW_MODEL=ponyDiffusionV6XL_v6StartWithThisOne.safetensors
SD_NEGATIVE_PROMPT=lowres, blurry, bad anatomy, extra fingers, watermark, text, logo, signature, child, loli, shota
SD_STEPS=28
SD_WIDTH=768
SD_HEIGHT=768
SD_CFG_SCALE=6.5
# The host is shared: allow Forge time for its global queue and checkpoint swaps.
SD_TIMEOUT_MS=300000
SD_QUEUE_TIMEOUT_MS=300000
SD_QUEUE_POLL_MS=2000
# Enable OpenPose only when the bot finds a neutral SearXNG pose reference for a complex pose.
SD_CONTROLNET_ENABLED=true
SD_CONTROLNET_OPENPOSE_MODEL=OpenPoseXL2
SD_CONTROLNET_WEIGHT=0.85
SD_CONTROLNET_PROCESSOR_RESOLUTION=512
AUTOPOST_ENABLED=true              # master switch for the scheduler tick
AUTOPOST_DEFAULT_ENABLED=false     # per-chat default (opt-in via /autopost to avoid spam)
AUTOPOST_INTERVAL_MINUTES=10       # minutes between autopost scheduler ticks
AUTOPOST_PROBABILITY=0.05          # per eligible chat, each interval
AUTOPOST_IMAGE_RATIO=0.4           # share of autoposts that are a waifu image vs a news take
GENERATED_IMAGE_AUTOPOST_ENABLED=false # separate generated-image scheduler; enable only after quality approval
GENERATED_IMAGE_AUTOPOST_INTERVAL_MINUTES=10
GENERATED_IMAGE_AUTOPOST_PROBABILITY=0.05
RSS_FEEDS=                         # comma-separated feed URLs (defaults include cyber/AI/crypto + general news)
NEWS_MAX_AGE_HOURS=12              # ignore RSS items older than this and older than today's UTC date

# ---- NSFW model routing (optional) ----
# Uncensored model used for adult/NSFW text. Leave empty to disable NSFW routing entirely.
# Routing is hybrid + per-chat gated (admins use /nsfw off|base|smart):
#   - a mode flagged [nsfw] always uses this model
#   - chat 'base'  => whole chat uses this model
#   - chat 'smart' => per-message lexicon decides; if the default model still refuses, the
#                     buffered backstop silently retries with this model
LLM_NSFW_MODEL=                    # optional; leave empty to use LLM_MODEL for every request
# Optional: run the NSFW model on a SEPARATE backend (e.g. a router that hosts amoral-gemma) while
# the primary chat runs elsewhere. Empty => the NSFW model is requested from LLM_BASE_URL/LLM_API_KEY.
LLM_NSFW_BASE_URL=                 # separate endpoint hosting the NSFW model; empty = reuse LLM_BASE_URL
LLM_NSFW_API_KEY=                  # bearer token for the NSFW endpoint
# initial per-chat NSFW mode for newly-seen chats: off | base | smart
# (smart => fast default model normally, NSFW model only on lexicon hit/refusal backstop)
LLM_NSFW_DEFAULT_MODE=smart        # initial per-chat mode: off | base | smart
# optional extra comma-separated trigger terms appended to the built-in lexicon (smart mode)
LLM_NSFW_LEXICON=                  # extra comma-separated trigger words (smart mode)
# buffered refusal backstop: if the default model refuses, retry with the NSFW model
LLM_REFUSAL_FALLBACK=true          # on a refusal, silently retry on the NSFW model
LLM_REFUSAL_BUFFER_CHARS=160       # how many leading chars to inspect for a refusal

# ---- Brain pipeline (per-stage models fall back to LLM_MODEL if empty) ----
SCENE_MODEL=                       # scene-analysis stage model; empty = use LLM_MODEL
REALISTIC_EVALUATOR_ENABLED=true   # LLM JSON evaluator for action/provider/tool routing
REALISTIC_EVALUATOR_MODEL=         # empty = use LLM_MODEL
REALISTIC_EVALUATOR_TEMPERATURE=0.1
PLANNER_MODEL=                     # reply-planning stage model; empty = use LLM_MODEL
REPLY_MODEL=                       # reply-generation stage model; empty = use LLM_MODEL
RANKER_MODEL=                      # candidate-ranking stage model; empty = use LLM_MODEL
MEMORY_MODEL=                      # fact-extraction stage model; empty = use LLM_MODEL
SCENE_TEMPERATURE=0.2              # low = deterministic scene reading
PLANNER_TEMPERATURE=0.3            # planning creativity
REPLY_TEMPERATURE=0.95            # high = spicier, more varied replies
RANKER_TEMPERATURE=0.1             # low = consistent candidate scoring
MEMORY_TEMPERATURE=0.1             # low = reliable fact extraction
# Reply generation: keep this at 1 for fast chat; raise only if you want extra sampling + ranking.
REPLY_CANDIDATE_COUNT=1            # replies sampled per turn (1 = fastest)
REPLY_MAX_REGENERATIONS=2          # retries if a reply is filtered or too repetitive
REPLY_TOP_P=0.95                   # nucleus sampling cutoff
REPLY_FREQUENCY_PENALTY=0.6        # discourage token repetition
REPLY_PRESENCE_PENALTY=0.4         # encourage new topics
MAX_REPLY_CHARS=420                # hard cap on reply length (chars)
MAX_REPLY_LINES=3                  # hard cap on reply lines
REPETITION_SIMILARITY_THRESHOLD=0.72   # >= this similarity vs recent replies => regenerate (0-1)
# Memory engine
MEMORY_MANUAL_MIN_CONFIDENCE=0.62  # min confidence to store a user-asserted fact
MEMORY_AUTO_MIN_CONFIDENCE=0.75    # min confidence to store an auto-mined fact
MEMORY_MIN_CONFIDENCE=0.68         # min confidence to recall a fact into context
MEMORY_MIN_SALIENCE=0.45           # min salience for a fact to be worth recalling
MEMORY_MAX_CANDIDATES_PER_RUN=5    # max facts considered per extraction pass
MEMORY_MAX_ITEMS_PER_REPLY=3       # max memories injected into one reply
MEMORY_MAX_EXPLICIT_CALLBACKS_PER_REPLY=1   # max "as you said earlier" callbacks per reply
MEMORY_ITEM_COOLDOWN_MINUTES=45    # min gap before re-using the same memory
MEMORY_SUBJECT_COOLDOWN_MINUTES=20 # min gap before re-using memories about the same subject
FACT_EXTRACTION_CONTEXT_MESSAGES=30   # messages of context fed to the fact miner
FACT_REPLY_CONTEXT_BEFORE=10       # messages before a reply used for fact linking
FACT_REPLY_CONTEXT_AFTER=10        # messages after a reply used for fact linking
# Background jobs
MEMORY_MINING_ENABLED=true         # periodically mine facts from active chats
MEMORY_MINING_EVERY_MESSAGES=25    # mine after this many new messages in a chat
MEMORY_MINING_INTERVAL_SECONDS=300 # how often the miner runs
MEMORY_MINING_MIN_ACTIVE_MESSAGES=8   # skip mining a chat below this activity
FEEDBACK_LEARNING_ENABLED=true     # learn from reactions/replies to the bot's messages
FEEDBACK_LOOKAHEAD_MESSAGES=10     # messages after a bot reply scanned for feedback
BRAIN_DEBUG_ENABLED=true           # store per-stage brain traces (for /debug)
DEBUG_COMMANDS_ADMIN_ONLY=true     # restrict /brain and /debuglast style commands to admins
BRAIN_DEBUG_TTL_DAYS=7             # days to keep brain debug traces
BOT_REPLIES_RETENTION_DAYS=30      # days to keep the bot's own reply log

# ---- Voice: TTS (OpenAI-compatible /v1/audio/speech, e.g. Kokoro-FastAPI) ----
# Run `scripts/setup-voice.sh` first (downloads ffmpeg + builds whisper.cpp into vendor/).
TTS_ENABLED=false                  # enable text-to-speech voice replies
TTS_BASE_URL=                      # TTS server base (e.g. http://host:8880); empty = disabled
TTS_MODEL=tts-1                    # TTS model id the server expects
# Italian voices: im_nicola (m) / if_sara (f). English: af_heart, am_michael, ...
TTS_VOICE=im_nicola                # voice id (see options on the line above)
TTS_API_KEY=                       # api key for the TTS server; empty = none
# opus asks the server for OGG/Opus; when ffmpeg is available the bot still re-finalizes it and
# appends a silent tail so Telegram clients do not clip the last word.
TTS_FORMAT=opus                    # opus = Telegram-ready (no local ffmpeg); or wav / mp3
TTS_SPEED=1                        # playback speed multiplier
TTS_MAX_CHARS=600                  # skip TTS above this many chars
TTS_TIMEOUT_MS=30000               # max time to wait for a TTS request
TTS_TAIL_PADDING_MS=600            # real silence appended after TTS to stop Telegram clipping the last word
TTS_AUTO_VOICE_PROBABILITY=0.12    # chance to answer with voice unprompted
TTS_REPLY_TO_VOICE=true            # always reply by voice when the user sent voice

# ---- Voice: STT (local whisper.cpp) ----
STT_ENABLED=false                  # enable speech-to-text (transcribe voice/audio/video)
# paths default to the vendor/ toolchain provisioned by scripts/setup-voice.sh
WHISPER_BIN=vendor/whisper.cpp/build/bin/whisper-cli   # path to whisper-cli binary
WHISPER_MODEL=vendor/models/ggml-base.bin              # path to the ggml whisper model
FFMPEG_BIN=/usr/bin/ffmpeg         # ffmpeg path. Prefer a system ffmpeg (apt install ffmpeg): it handles network/HLS input for link-media snapshots. vendor/bin/ffmpeg works for local media only.
STT_LANGUAGE=auto                  # force a language code (e.g. it) or auto-detect
STT_THREADS=4                      # whisper CPU threads
STT_TIMEOUT_MS=60000               # max time to wait for a transcription
STT_TRANSCRIBE_ALL=true            # transcribe every voice/audio/video, not just replies to the bot

# ---- Music: /sing /play + natural language ("mi canti X", "suona X", "play X", "cantame X") ----
# Searches YouTube via yt-dlp, extracts up to MUSIC_MAX_DURATION_SECONDS of audio, converts to
# OGG/Opus and sends it as a voice note. Needs yt-dlp + ffmpeg (scripts/setup-voice.sh installs both).
MUSIC_ENABLED=true                 # master switch for /sing /play and the natural-language triggers
YTDLP_BIN=vendor/bin/yt-dlp        # path to the yt-dlp binary (absolute, or a name on PATH)
MUSIC_MAX_DURATION_SECONDS=720     # cap on extracted audio length (720 = 12 minutes)
MUSIC_TIMEOUT_MS=240000            # total budget for one search + download + transcode
MUSIC_PROXY=                       # optional outbound proxy for yt-dlp (empty = direct)

# ---- Link media rehost: download media from URLs posted in chat, re-upload as Telegram files ----
# Two paths: video streams (YouTube, TikTok, Vimeo, Twitch, Facebook, Reddit video, adult/cam) are
# downloaded with the vendored yt-dlp binary; social posts (X/Twitter, Instagram, Bluesky) are sent
# as images plus context (post text, likes, reposts). Imgur/Giphy/Tenor/direct links fetched directly,
# generic OpenGraph fallback for the rest. ffmpeg normalizes for Telegram. Toggle per chat: /linkmedia.
LINK_MEDIA_ENABLED=true                       # master switch for link rehosting
LINK_MEDIA_AUTO_REHOST=true                   # rehost automatically when a media URL is posted
LINK_MEDIA_AI_COMMENT_ENABLED=true            # transcribe/vision-describe short clips into AI context
LINK_MEDIA_COMMENT_ONLY_WHEN_ADDRESSED=false  # true = only enrich context when the bot is tagged
LINK_MEDIA_MAX_URLS_PER_MESSAGE=2             # how many URLs to process per message
LINK_MEDIA_MAX_MEDIA_PER_URL=6                # max media items pulled from one carousel/gallery
LINK_MEDIA_MAX_DOWNLOAD_MB=150                # hard cap on bytes downloaded per item
LINK_MEDIA_MAX_UPLOAD_MB=45                   # skip if the normalized file exceeds this (Telegram bot limit ~50MB)
LINK_MEDIA_MAX_DURATION_SECONDS=180           # do not rehost videos longer than this
LINK_MEDIA_AI_MAX_DURATION_SECONDS=90         # only enrich (STT/vision) clips up to this length
LINK_MEDIA_TIMEOUT_MS=240000                  # budget per URL (extract + download + transcode)
LINK_MEDIA_CHAT_COOLDOWN_SECONDS=8            # min gap between rehosts in a chat (anti-spam)
LINK_MEDIA_USER_COOLDOWN_SECONDS=20           # min gap between rehosts per user
LINK_MEDIA_TMP_DIR=.tmp-link-media            # scratch dir (gitignored, cleaned per job)
LINK_MEDIA_ALLOWED_HOSTS=                     # comma-separated allowlist (empty = allow all non-blocked)
LINK_MEDIA_BLOCKED_HOSTS=                     # comma-separated denylist of hosts to never fetch
LINK_MEDIA_NSFW_ALLOW=false                   # allow known adult hosts (off by default)
LINK_MEDIA_COOKIES_INSTAGRAM=                 # REQUIRED for instagram now: a Cookie header string OR a path to a cookies.txt (logged-out IG returns no media)
LINK_MEDIA_COOKIES_TIKTOK=                    # optional cookie string for tiktok
LINK_MEDIA_COOKIES_FACEBOOK=                  # optional cookie string for facebook
LINK_MEDIA_COOKIES_X=                         # optional cookie string for x/twitter
LINK_MEDIA_PROXY=                             # optional outbound proxy for downloads (empty = direct)
LINK_MEDIA_CACHE_TTL_DAYS=30                  # how long to keep the url -> Telegram file_id cache

# ---- Option B: DeepSeek ----
# Set LLM_PROVIDER=deepseek and fill these. (DEEPSEEK_* take priority over LLM_* for deepseek.)
DEEPSEEK_API_KEY=                  # only used when LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com   # DeepSeek API base URL
DEEPSEEK_MODEL=                    # e.g. deepseek-chat

# ---- Option C: local Ollama ----
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.1

# ---- Option D: OpenAI ----
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ---- Option E: any other OpenAI-compatible backend ----
# LLM_PROVIDER=custom_openai_compatible
# LLM_BASE_URL=https://your-host/v1
# LLM_API_KEY=...
# LLM_MODEL=...

# =============================================================================
# Behaviour defaults & limits
# =============================================================================
# Default chat language (italian | english | russian | spanish). Changeable at runtime with /language.
DEFAULT_LANGUAGE=italian           # italian | english | russian | spanish

# Per-chat feature toggles - initial value when a chat is first seen (admins can flip at runtime).
AUTOENGAGE_DEFAULT_ENABLED=true    # bot may chime in unprompted in new chats
CONVERSATION_TRACKER_DEFAULT_ENABLED=true   # track who-said-what threads for context
AUTOFACT_DEFAULT_ENABLED=false     # auto-extract facts without /remember (off by default)

# Autoengage pacing / anti-spam
MAX_REPLIES_PER_CHAT_PER_HOUR=72   # global safety ceiling; /profile enforces the lower group cap
AUTOENGAGE_MIN_COOLDOWN_SECONDS=45 # min gap between unprompted replies in a chat
AUTOENGAGE_USER_COOLDOWN_SECONDS=20   # min gap before re-engaging the same user
AUTOENGAGE_MIN_CONFIDENCE=0.6      # min "worth replying" score to chime in (0-1)

# Conversation memory / retention
MESSAGE_HISTORY_RETENTION_DAYS=30  # days of chat history kept
MAX_CONTEXT_MESSAGES=25            # messages of history fed to the model
MAX_STORED_MESSAGES_PER_CHAT=500   # ring-buffer size per chat

# Usage limit (points per user per month). Large default => effectively unlimited.
DEFAULT_USAGE_LIMIT=1000000000     # points/user/month; huge value = effectively unlimited

# Moderation
# Default ban duration in seconds when /ban is used without one. 0 => permanent.
DEFAULT_BAN_SECONDS=0              # /ban default duration in seconds; 0 = permanent
# Min seconds between accepted command invocations per user (anti-spam).
COMMAND_RATE_LIMIT_SECONDS=1       # min seconds between commands per user

# Streaming UX
ENABLE_MESSAGE_STREAMING=true      # stream replies via live message edits
STREAM_EDIT_INTERVAL_MS=1200       # min ms between streamed edits (Telegram rate limit)
