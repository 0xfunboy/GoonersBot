# =============================================================================
# GoonerBot — environment configuration
# Copy to .env and fill in. Never commit your real .env (it is gitignored).
# Required: TELEGRAM_BOT_TOKEN. Everything else has sensible defaults.
# =============================================================================

# ---- Runtime ----
NODE_ENV=development
LOG_LEVEL=info

# ---- Telegram ----
# Get a token from @BotFather. REQUIRED.
TELEGRAM_BOT_TOKEN=
# Default/hint only — the real username is resolved from Telegram at startup.
BOT_USERNAME=GoonerBot

# Access control. Comma-separated @handles.
# ALLOWED_HANDLES: who may use the bot. Empty or "*" => everyone (recommended for a public group).
# ADMIN_HANDLES: bot admins (can /ban, /unban). Empty => no bot admins.
ALLOWED_HANDLES=*
ADMIN_HANDLES=

# ---- MongoDB ----
# Local Mongo (no Docker). Install/run MongoDB locally, e.g. `mongod --dbpath ./.mongo-data`.
MONGO_URI=mongodb://127.0.0.1:27017/goonerbot
MONGO_DB=goonerbot

# =============================================================================
# LLM provider
# Select ONE provider. The host is configurable — never hardcoded in the code.
# Supported: solclawn | openai | deepseek | ollama | custom_openai_compatible
# =============================================================================

# ---- Option A: solclawn (OpenAI-compatible LeakRouter surface) ----
# LLM_API_KEY is the LeakRouter client bearer token. LLM_MODEL is an Ollama model name.
LLM_PROVIDER=solclawn
LLM_BASE_URL=https://llm.solclawn.com/v1
LLM_API_KEY=
LLM_MODEL=
# Optional media models (leave empty to disable that capability — the bot degrades gracefully):
LLM_VISION_MODEL=
LLM_IMAGE_MODEL=
LLM_TRANSCRIPTION_MODEL=
LLM_TTS_MODEL=
LLM_REQUEST_TIMEOUT_MS=60000

# ---- NSFW model routing (optional) ----
# Uncensored model used for adult/NSFW text. Leave empty to disable NSFW routing entirely.
# Routing is hybrid + per-chat gated (admins use /nsfw off|base|smart):
#   - a mode flagged [nsfw] always uses this model
#   - chat 'base'  => whole chat uses this model
#   - chat 'smart' => per-message lexicon decides; if the default model still refuses, the
#                     buffered backstop silently retries with this model
LLM_NSFW_MODEL=
# initial per-chat NSFW mode for newly-seen chats: off | base | smart
# (smart => fast default model normally, NSFW model only on lexicon hit/refusal backstop)
LLM_NSFW_DEFAULT_MODE=smart
# optional extra comma-separated trigger terms appended to the built-in lexicon (smart mode)
LLM_NSFW_LEXICON=
# buffered refusal backstop: if the default model refuses, retry with the NSFW model
LLM_REFUSAL_FALLBACK=true
LLM_REFUSAL_BUFFER_CHARS=160

# ---- Brain pipeline (per-stage models fall back to LLM_MODEL if empty) ----
SCENE_MODEL=
PLANNER_MODEL=
REPLY_MODEL=
RANKER_MODEL=
MEMORY_MODEL=
SAFETY_MODEL=
SCENE_TEMPERATURE=0.2
PLANNER_TEMPERATURE=0.3
REPLY_TEMPERATURE=0.95
RANKER_TEMPERATURE=0.1
MEMORY_TEMPERATURE=0.1
# Reply generation: keep this at 1 for fast chat; raise only if you want extra sampling + ranking.
REPLY_CANDIDATE_COUNT=1
REPLY_MAX_REGENERATIONS=2
REPLY_TOP_P=0.95
REPLY_FREQUENCY_PENALTY=0.6
REPLY_PRESENCE_PENALTY=0.4
MAX_REPLY_CHARS=420
MAX_REPLY_LINES=3
REPETITION_SIMILARITY_THRESHOLD=0.72
# Memory engine
MEMORY_MANUAL_MIN_CONFIDENCE=0.62
MEMORY_AUTO_MIN_CONFIDENCE=0.75
MEMORY_MIN_CONFIDENCE=0.68
MEMORY_MIN_SALIENCE=0.45
MEMORY_MAX_CANDIDATES_PER_RUN=5
MEMORY_MAX_ITEMS_PER_REPLY=3
MEMORY_MAX_EXPLICIT_CALLBACKS_PER_REPLY=1
MEMORY_ITEM_COOLDOWN_MINUTES=45
MEMORY_SUBJECT_COOLDOWN_MINUTES=20
FACT_EXTRACTION_CONTEXT_MESSAGES=30
FACT_REPLY_CONTEXT_BEFORE=10
FACT_REPLY_CONTEXT_AFTER=10
# Background jobs
MEMORY_MINING_ENABLED=true
MEMORY_MINING_INTERVAL_SECONDS=300
MEMORY_MINING_MIN_ACTIVE_MESSAGES=8
FEEDBACK_LEARNING_ENABLED=true
FEEDBACK_LOOKAHEAD_MESSAGES=10
BRAIN_DEBUG_ENABLED=true
BRAIN_DEBUG_TTL_DAYS=7
BOT_REPLIES_RETENTION_DAYS=30

# ---- Option B: DeepSeek ----
# Set LLM_PROVIDER=deepseek and fill these. (DEEPSEEK_* take priority over LLM_* for deepseek.)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=

# ---- Option C: local Ollama ----
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.1

# ---- Option D: OpenAI ----
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ---- Option E: any other OpenAI-compatible backend ----
# LLM_PROVIDER=custom_openai_compatible
# LLM_BASE_URL=https://your-host/v1
# LLM_API_KEY=...
# LLM_MODEL=...

# =============================================================================
# Behaviour defaults & limits
# =============================================================================
# Default chat language (italian | english | russian | spanish). Changeable at runtime with /language.
DEFAULT_LANGUAGE=italian

# Per-chat feature toggles — initial value when a chat is first seen (admins can flip at runtime).
AUTOENGAGE_DEFAULT_ENABLED=true
CONVERSATION_TRACKER_DEFAULT_ENABLED=true
AUTOFACT_DEFAULT_ENABLED=false

# Autoengage pacing / anti-spam
MAX_REPLIES_PER_CHAT_PER_HOUR=15
AUTOENGAGE_MIN_COOLDOWN_SECONDS=45
AUTOENGAGE_USER_COOLDOWN_SECONDS=20
AUTOENGAGE_MIN_CONFIDENCE=0.6

# Conversation memory / retention
MESSAGE_HISTORY_RETENTION_DAYS=30
MAX_CONTEXT_MESSAGES=25
MAX_STORED_MESSAGES_PER_CHAT=500

# Usage limit (points per user per month). Large default => effectively unlimited.
DEFAULT_USAGE_LIMIT=1000000000

# Moderation
# Default ban duration in seconds when /ban is used without one. 0 => permanent.
DEFAULT_BAN_SECONDS=0
# Min seconds between accepted command invocations per user (anti-spam).
COMMAND_RATE_LIMIT_SECONDS=1

# Streaming UX
ENABLE_MESSAGE_STREAMING=true
STREAM_EDIT_INTERVAL_MS=1200
